    <div class="mt-5 flex">
        <div class="bg-[#121212] w-16 h-16 rounded-lg flex justify-center items-center mr-4">
            <img src="/html-1.svg" alt="Logo html" width="30" height="30">
        </div>
        <div class="bg-[#121212] w-16 h-16 rounded-lg flex justify-center items-center mr-4">
            <img src="/css-3.svg" alt="Logo css" width="30" height="30">
        </div>
        <div class="bg-[#121212] w-16 h-16 rounded-lg flex justify-center items-center mr-4">
            <img src="/logo-javascript.svg" alt="Logo javascript" width="30" height="30">
        </div>
        <div class="bg-[#121212] w-16 h-16 rounded-lg flex justify-center items-center mr-4">
            <img src="/typescript.svg" alt="Logo typescript" width="30" height="30">
        </div>
        <div class="bg-[#121212] w-16 h-16 rounded-lg flex justify-center items-center mr-4">
            <img src="/tailwindcss.svg" alt="Logo tailwind" width="30" height="30">
