        </div>
        <div class="bg-[#121212] w-16 h-16 rounded-lg flex justify-center items-center mr-4">
            <img src="/nextjs.svg" alt="Logo nextjs" width="30" height="30">
        </div>
        <div class="bg-[#121212] w-16 h-16 rounded-lg flex justify-center items-center mr-4">
            <img src="/astro_dark.svg" alt="Logo astro" width="30" height="30">
